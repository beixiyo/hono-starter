{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": [
      "bun"
    ],
    "allowImportingTsExtensions": true,
    "experimentalDecorators": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}