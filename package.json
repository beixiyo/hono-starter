{
  "name": "hono-demo-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run -F app dev",
    "build": "bun run -F '*' build",
    "test": "bun run -F '*' test",
    "lint": "bun run -F '*' lint",
    "======== db =========": "=================",
    "db:push": "bun x drizzle-kit push",
    "db:generate": "bun x drizzle-kit generate",
    "db:migrate": "bun x drizzle-kit migrate",
    "======== publish =========": "=================",
    "publish:test": "bun scripts/publish.cjs test",
    "publish:prod": "bun scripts/publish.cjs prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@jl-org/deploy": "^1.0.9",
    "@jl-org/eslint-plugins": "^1.0.0",
    "@types/bun": "^1.3.8",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.0"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  }
}
